{
  "modules-left": ["sway/workspaces", "sway/window", "sway/mode"],
  "modules-right": ["pulseaudio", "backlight", "network", "battery", "clock"],
  "clock": {
    "format": "{:%d %b _ %I : %M}"
  },
  "backlight": {
    "format": "{percent}%  {icon}",
    "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
    "on-scroll-up": "light -A 1",
    "on-scroll-down": "light -U 1"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ≤░λζ",
    "format-plugged": "{capacity}% ΎΘο",
    "format-alt": "{time} {icon}",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },
  "pulseaudio": {
    "format": "{volume}%  {icon}    {format_source}",
    "format-bluetooth": "{volume}%  {icon}   ΎΛΦ   {format_source}",
    "format-bluetooth-muted": "≤░ζθ {icon}ΎΛΦ {format_source}",
    "format-muted": "≤░ζθ {format_source}",
    "format-source": "{volume}%  ΎΕ░",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "≤▒ι░",
      "headset": "≤░ΜΟ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol"
  },
  "network": {
    "format": "{ifname}",
    "format-wifi": "Connected ΎΘτ",
    "format-ethernet": "{ipaddr}/{cidr} ≤░ΙΑ",
    "format-disconnected": "Disconnected ≤▒δΖ", //An empty format will hide the module.
    "max-length": 50
  },
  "sway/workspaces": {
